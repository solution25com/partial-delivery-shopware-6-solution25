{% block partial_shipment_create %}
	<div class="shipment-container">
		<sw-loader v-if="isLoading" size="large" class="shipment-loader"/>
		<template v-else>
			<sw-button v-if="shipments.length > 0 && !showCreateShipment && !showUpdateShipment" variant="primary" class="custom-save-all-bundles-button" @click="toggleShipmentCreation">
				Create Shipment
			</sw-button>

			<sw-order-detail-shipment-create
					v-if="showCreateShipment"
					@close-shipment-form="toggleShipmentCreation"
					@shipment-created="onShipmentCreated">
			</sw-order-detail-shipment-create>

			<sw-order-detail-shipment-update
					v-if="showUpdateShipment"
					:shipment="shipmentBeingEdited"
					@close-shipment-form="toggleShipmentUpdate"
					@shipment-updated="onShipmentUpdated"
			/>


			<sw-card class="full-width-card" v-if="!hasPartialDelivery && !showCreateShipment && !showUpdateShipment">
				<sw-button variant="primary" class="custom-save-all-bundles-button" @click="toggleShipmentCreation">
					Create Shipment
				</sw-button>
				<div class="no-shipments">
					No shipment details found for this order!
				</div>
			</sw-card>
			<table v-if="hasPartialDelivery && !showCreateShipment && !showUpdateShipment"  class="sw-table">
				<thead>
					<tr>
						<th>Prod. no.</th>
						<th>Ordered</th>
						<th>Canceled</th>
						<th>Shipped</th>
						<th>Shipment Details</th>
					</tr>
				</thead>
				<tbody>
					<tr v-for="shipment in shipments" :key="shipment.lineItemId">
						<td>
							<div v-if="productDetails[shipment.productId]">
								{{ productDetails[shipment.productId].productNumber }}
								-
								{{ productDetails[shipment.productId].name }}
							</div>
						</td>
						<td>{{ shipment.quantityOrdered }}</td>

						<td>
							{{ shipment.quantityLeft }}
						</td>

						<td>{{ shipment.quantityShipped }}</td>
						<td>
							<table class="shipment-details">
								<thead>
									<tr>
										<th>Box</th>
										<th>Qty</th>
										<th>Tracking</th>
										<th>Created at</th>
										<th>Action</th>
									</tr>
								</thead>
								<tbody>
									<tr v-for="(s, index) in shipment.shipments" :key="index">
										<td>{{ s.package }}</td>
										<td class="quantity">{{ s.quantity }}</td>
										<td>{{ s.trackingCode }}</td>
										<td>{{ formatDateTime(s.createdAt) }}</td>
										<td>
											<sw-button
												variant="primary"
												size="small"
												@click="startShipmentEdit(s, shipment)"
											>
												Edit
											</sw-button>
											<sw-button variant="danger" class="partialDelivery_delete_shipments" size="small" @click="promptDeleteShipment(s)">
												Delete
											</sw-button>
										</td>
									</tr>
								</tbody>
							</table>
						</td>
					</tr>
				</tbody>
			</table>

			<sw-modal
				v-if="shipmentPendingDeletion"
				title="Delete shipment"
				variant="small"
				@modal-close="closeDeleteModal"
			>
				<p>Are you sure you want to delete this shipment?</p>

				<template #modal-footer>
					<sw-button variant="secondary" @click="closeDeleteModal">
						Cancel
					</sw-button>
					<sw-button class="partialDelivery_delete_shipments" variant="danger" @click="deleteShipment">
						Delete shipment
					</sw-button>
				</template>
			</sw-modal>
		</template>
	</div>
{% endblock %}
