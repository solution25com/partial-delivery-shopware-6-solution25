{
    "name": "solution25/partial-delivery",
    "description": "Partial Delivery - Shopware 6 Plugin",
    "type": "shopware-platform-plugin",
    "version": "1.2.0",
    "license": "MIT",
    "authors": [
        {
            "name": "solution25",
            "email": "info@solution25.com",
            "homepage": "https://solution25.com/"
        }
    ],
    "require": {
        "shopware/core": "^6.6 || ^6.7"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "suggest": {
        "swag/commercial": "Required for the return-management integration. Install and activate Shopware Commercial (Return Management) before activating this plugin."
    },
    "extra": {
        "shopware-plugin-class": "PartialDelivery\\PartialDelivery",
        "label": {
            "de-DE": "Teil-Lieferung",
            "en-GB": "Partial Delivery"
        },
        "description": {
            "de-DE": "Dieses Plugin erweitert Shopware um die Möglichkeit, Bestellungen in mehrere Teillieferungen aufzuteilen, Sendungen zu verwalten und Lieferprozesse effizient zu steuern.",
            "en-GB": "This plugin extends Shopware by enabling partial deliveries, allowing merchants to split orders into multiple shipments and manage delivery processes more efficiently."
        },
        "manufacturerLink": {
            "de-DE": "https://solution25.com/",
            "en-GB": "https://solution25.com/en/home_en/"
        },
        "supportLink": {
            "de-DE": "https://solution25.com/",
            "en-GB": "https://solution25.com/en/home_en/"
        }
    },
    "autoload": {
        "psr-4": {
            "PartialDelivery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PartialDelivery\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@enable-prepush"
        ],
        "post-update-cmd": [
            "@enable-prepush"
        ],
        "enable-prepush": [
            "cp ./pre-push .git/hooks/pre-push",
            "chmod +x .git/hooks/pre-push"
        ]
    }
}
